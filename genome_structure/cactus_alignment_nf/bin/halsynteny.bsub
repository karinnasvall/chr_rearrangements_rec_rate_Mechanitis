module load cactus/v3.1.2

INPUT_HAL=/lustre/scratch125/tol/teams/meier/users/kn9/recombination/breakpoints/cactus_260321/output/Mec_align.hal
OUTPUT_DIR=output_halsynteny

GENOME1="ilMecPoly1"
GENOME2="ilMecLysi212"
ANCESTOR="N7"

min_block_size=5000
max_block_distance=5000

mkdir -p ${OUTPUT_DIR}

# halSynteny --queryGenome ${GENOME1} \
#            --targetGenome ${GENOME2} \
