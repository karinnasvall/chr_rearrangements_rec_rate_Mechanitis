# ancestor-genome comparisons
halSynteny --queryGenome ${GENOME2} \
           --targetGenome ${ANCESTOR} \
           ${INPUT_HAL} ${OUTPUT_DIR}/halsynteny_${GENOME2}_${ANCESTOR}.psl



# halSynteny --help
 
# /home/cactus/bin/halSynteny v2.2: Convert alignments into synteny blocks

# USAGE:
