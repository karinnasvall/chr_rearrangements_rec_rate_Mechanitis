/*
 * ==============================================
 *  Breakpoint Detection Pipeline - Configuration
 * ==============================================
 */

params {
    // ===== INPUT =====
    genome_list        = null          // Text file: one genome path per line (hap1 and hap2)
    outdir             = 'results'     // Output directory

    // ===== GENOME FILTERING =====
    min_scaffold_size  = 500000        // Minimum scaffold size (bp) to keep
    move_w             = true          // Move W chromosomes from hap1 to hap2

    // ===== BUSCO =====
    busco_lineage      = 'lepidoptera_odb12'
    skip_busco         = false         // Skip BUSCO; requires precomputed_busco_dir
    precomputed_busco_dir = null       // Dir with {tolid}_hap1_single_copy.faa files

    // ===== ORTHOFINDER =====
    user_tree          = null          // Optional: user species tree for OrthoFinder (-s flag)
    skip_orthofinder   = false         // Skip OrthoFinder; requires precomputed_orthofinder_dir
    precomputed_orthofinder_dir = null // Path to OrthoFinder results/latest/ directory

    // ===== SYNGRAPH =====
    syngraph_path      = '/software/team347/kn9/syngraph/syngraph'
    ref_genome         = null          // Reference genome tolid for syngraph infer (REQUIRED)
    syngraph_m_min     = 5             // Minimum m value for syngraph infer
    syngraph_m_max     = 30            // Maximum m value for syngraph infer

    // ===== AGORA =====
    agora_path         = '/software/team347/kn9/Agora/src/agora-basic.py'
}

// ===== PROCESS RESOURCES (LSF clusterOptions) =====
process {
    executor = 'lsf'

    withName: 'PREPARE_GENOMES' {
        clusterOptions = '-n 1 -q normal -W 02:00 -M 4000 -R "select[mem>4000] rusage[mem=4000] span[hosts=1]"'
        module = ['seqkit/2.8.2--h9ee0642_0', 'samtools/1.20--h50ea8bc_0']
    }

    withName: 'BUSCO' {
        cpus = 12
        clusterOptions = '-n 12 -q normal -W 12:00 -M 20000 -R "select[mem>20000] rusage[mem=20000]"'
        module = 'busco/6.0.0--pyhdfd78af_0'
    }

    withName: 'STAGE_ORTHOFINDER_INPUT' {
        clusterOptions = '-n 1 -q normal -W 01:00 -M 2000 -R "select[mem>2000] rusage[mem=2000] span[hosts=1]"'
    }

    withName: 'ORTHOFINDER' {
        cpus = 12
        clusterOptions = '-n 12 -q long -W 48:00 -M 30000 -R "select[mem>30000] rusage[mem=30000]"'
        module = 'orthofinder/3.1.0--hdfd78af_0'
    }

    withName: 'PREP_SYNGRAPH_INPUT' {
        clusterOptions = '-n 1 -q normal -W 01:00 -M 2000 -R "select[mem>2000] rusage[mem=2000] span[hosts=1]"'
    }

    withName: 'SYNGRAPH' {
        cpus = 2
        clusterOptions = '-n 2 -q normal -W 04:00 -M 5000 -R "select[mem>5000] rusage[mem=5000]"'
        beforeScript = 'eval "$(conda shell.bash hook)" && conda activate syngraph'
    }

    withName: 'PREP_AGORA_INPUT' {
        clusterOptions = '-n 1 -q normal -W 01:00 -M 2000 -R "select[mem>2000] rusage[mem=2000] span[hosts=1]"'
        beforeScript = 'eval "$(conda shell.bash hook)" && conda activate agora'
    }

    withName: 'AGORA' {
        cpus = 8
        clusterOptions = '-n 8 -q normal -W 04:00 -M 5000 -R "select[mem>5000] rusage[mem=5000]"'
        beforeScript = 'eval "$(conda shell.bash hook)" && conda activate agora'
    }
}

// ===== EXECUTOR =====
executor {
    name = 'lsf'
}
